{
  "manifest_version": 3,
  "name": "PostFlow Notifier",
  "version": "1.1.0",
  "description": "Recebe notificações dos seus posts agendados no PostFlow — 10 min antes e na hora exata.",
  "permissions": ["storage", "alarms", "notifications"],
  "host_permissions": ["https://vibe-queue-up.lovable.app/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
